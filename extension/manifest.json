{
  "manifest_version": 3,
  "name": "도우미누오: 스마트누오 전용 편의성 확장 프로그램",
  "version": "1.1.0",
  "description": "스마트누오 사용자를 위한 필수 어시스턴트입니다. 샘플 변환부터 계산기 자동 입력, 파티 결정력 및 내구력 표시까지, 사이트 이용을 더욱 빠르고 간편하게 바꿔주는 강력한 편의 기능을 제공합니다.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://smartnuo.com/*",
    "https://www.smartnuo.com/*",
    "https://pokeapi.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "환경설정",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://smartnuo.com/*", "https://www.smartnuo.com/*"],
      "js": [
        "calcFillShared.js",
        "calcFill.js",
        "teamBuilderFill.js",
        "regulationMaSpeedData.js",
        "speedOutspeedCalc.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
