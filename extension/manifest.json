{
  "manifest_version": 3,
  "name": "도우미누오",
  "version": "1.0.0",
  "description": "스마트누오 웹사이트 사용자를 위한 각종 편의 기능을 제공합니다. 샘플 변환, 계산기 자동 입력, 파티 결정력·내구력 표시 등을 지원합니다.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://smartnuo.com/*",
    "https://www.smartnuo.com/*",
    "https://pokeapi.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "환경설정",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://smartnuo.com/*", "https://www.smartnuo.com/*"],
      "js": ["calcFillShared.js", "calcFill.js", "teamBuilderFill.js"],
      "run_at": "document_idle"
    }
  ]
}
